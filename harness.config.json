{
  "orchestrator": {
    "enable_subagents": true,
    "workflow_mode": "lightning",
    "lightning_mode": {
      "auto_route_through_skills": false,
      "max_tool_calls_per_response": 5,
      "default_budget": {
        "max_steps": 60,
        "max_tokens": 12000,
        "max_duration_ms": 300000
      }
    },
    "superpowered_mode": {
      "require_spec_approval": true,
      "require_plan_approval": true,
      "require_task_reviews": true,
      "require_verification_before_done": true,
      "artifact_paths": {
        "specs_dir": "documents/specs",
        "plans_dir": "documents/plans"
      },
      "initial_skill_chain": [
        "brainstorming",
        "writing-plans",
        "subagent-driven-development"
      ],
      "review_loop_max_iterations": 3
    },
    "skill_execution_timeout_s": 15.0
  },
  "skills": {
    "market_trusted_public_keys": [
      "E35LKCz0IaBXidb3PM4HDgos8ChGlsqez2zuFJJXnVc="
    ],
    "market_allow_v1_hash_fallback": false
  },
  "model": {
    "default_backend": "lmstudio",
    "allow_cloud_adapters": true,
    "lmstudio": {
      "base_url": "http://127.0.0.1:1234/v1",
      "model": "google/gemma-4-26b-a4b",
      "timeout_s": 240.0,
      "max_tokens": 4096,
      "temperature": 0.2
    }
  },
  "memory": {
    "semantic_backend": "sqlite",
    "enable_chroma": false,
    "graph_backend": "networkx"
  },
  "tools": {
    "deny_all_by_default": true,
    "allow_network": true,
    "allowed_paths": [
      "."
    ],
    "allowed_tool_names": [
      "shell_command",
      "web_fetch",
      "create_directory",
      "write_file",
      "append_file",
      "replace_in_file",
      "json_edit",
      "insert_at_line",
      "delete_range",
      "yaml_edit",
      "read_file",
      "list_directory",
      "rename_or_move",
      "delete_file",
      "search_workspace",
      "run_project_check",
      "run_tests",
      "lint_and_fix"
    ],
    "blocked_tool_names": [],
    "allowed_command_prefixes": [
      "where",
      "git",
      "python",
      "npm",
      "curl",
      "dir",
      "echo"
    ]
  },
  "execution": {
    "allowed_cwd_roots": [
      "."
    ],
    "allowed_command_prefixes": [
      "where",
      "git",
      "python",
      "npm",
      "dir",
      "echo"
    ],
    "max_runtime_s": 300,
    "max_output_bytes": 32768
  },
  "state_machine": {
    "default_budget": {
      "max_steps": 1000,
      "max_tokens": 2555,
      "max_duration_ms": 2700000
    }
  },
  "ingestion": {
    "enable_graphify_plugin": false
  },
  "api": {
    "require_api_key": true,
    "api_key": "read123",
    "require_admin_api_key": true,
    "admin_api_key": "admin123"
  },
  "reports": {
    "redact_by_default": true,
    "redacted_keys": [
      "api_key",
      "x_api_key",
      "authorization",
      "token",
      "secret",
      "password"
    ],
    "max_export_bytes": 262144,
    "cleanup_max_age_days": 7,
    "cleanup_glob": "*.json"
  },
  "logging": {
    "cleanup_max_age_days": 30
  }
}
