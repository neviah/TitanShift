{
  "orchestrator": {
    "enable_subagents": true,
    "workflow_mode": "lightning",
    "lightning_mode": {
      "auto_route_through_skills": false,
      "max_tool_calls_per_response": 5,
      "default_budget": {
        "max_steps": 60,
        "max_duration_ms": 300000
      }
    },
    "superpowered_mode": {
      "disable_run_timeout": true,
      "run_timeout_seconds": 3600,
      "disable_budget_timeout": false,
      "planner_max_steps": 3,
      "planner_max_tokens": 2000,
      "implementer_max_steps": 8,
      "implementer_max_tokens": 3000,
      "default_implementer_timeout_s": 180,
      "implementer_timeout_s": 180,
      "require_spec_approval": false,
      "require_plan_approval": false,
      "require_task_reviews": false,
      "require_verification_before_done": false,
      "artifact_paths": {
        "specs_dir": "documents/specs",
        "plans_dir": "documents/plans"
      },
      "initial_skill_chain": [
        "brainstorming",
        "writing-plans",
        "subagent-driven-development"
      ],
      "review_loop_max_iterations": 1,
      "skip_plan_phase": true
    },
    "skill_execution_timeout_s": 15.0
  },
  "skills": {
    "market_trusted_public_keys": [
      "E35LKCz0IaBXidb3PM4HDgos8ChGlsqez2zuFJJXnVc="
    ],
    "market_allow_v1_hash_fallback": false
  },
  "model": {
    "allow_cloud_adapters": true,
    "lmstudio": {
      "base_url": "http://127.0.0.1:1234/v1",
      "model": "",
      "max_tokens": 1536,
      "temperature": 0.2
    }
  },
  "memory": {
    "semantic_backend": "sqlite",
    "enable_chroma": false,
    "graph_backend": "networkx"
  },
  "tools": {
    "deny_all_by_default": false,
    "allow_network": true,
    "allowed_paths": [
      "."
    ],
    "allowed_tool_names": [
      "shell_command",
      "web_fetch",
      "web_browse",
      "get_location",
      "create_directory",
      "write_file",
      "append_file",
      "replace_in_file",
      "edit_file",
      "json_edit",
      "read_file",
      "list_directory",
      "rename_or_move",
      "delete_file",
      "search_workspace",
      "run_project_check"
    ],
    "blocked_tool_names": [],
    "permission_rules": [
      {
        "permission": "bash",
        "pattern": "git status*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "git log *",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "git diff*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "git show*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "git branch*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "npm test*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "npm run *",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "python --version*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "python -m pytest*",
        "action": "allow"
      },
      {
        "permission": "bash",
        "pattern": "git push*",
        "action": "ask"
      },
      {
        "permission": "bash",
        "pattern": "git reset*",
        "action": "ask"
      },
      {
        "permission": "bash",
        "pattern": "git rebase*",
        "action": "ask"
      },
      {
        "permission": "bash",
        "pattern": "npm install*",
        "action": "ask"
      },
      {
        "permission": "bash",
        "pattern": "npm publish*",
        "action": "ask"
      },
      {
        "permission": "bash",
        "pattern": "rm -rf*",
        "action": "deny"
      },
      {
        "permission": "bash",
        "pattern": "rmdir /s*",
        "action": "deny"
      },
      {
        "permission": "bash",
        "pattern": "del /f*",
        "action": "deny"
      },
      {
        "permission": "bash",
        "pattern": "format *",
        "action": "deny"
      },
      {
        "permission": "bash",
        "pattern": "mkfs*",
        "action": "deny"
      },
      {
        "permission": "bash",
        "pattern": "dd if=*",
        "action": "deny"
      }
    ],
    "allowed_command_prefixes": [
      "where",
      "git",
      "python",
      "npm",
      "curl",
      "dir",
      "echo"
    ],
    "doom_loop_invalid_threshold": 2
  },
  "execution": {
    "allowed_cwd_roots": [
      "."
    ],
    "allowed_command_prefixes": [
      "where",
      "git",
      "python",
      "npm",
      "dir",
      "echo"
    ],
    "max_runtime_s": 300,
    "max_output_bytes": 32768,
    "run_timeout_seconds": 1800
  },
  "state_machine": {
    "default_budget": {
      "max_steps": 40,
      "max_tokens": 100000,
      "max_duration_ms": 600000
    },
    "invalid_tool_retry_limit": 2
  },
  "ingestion": {
    "enable_graphify_plugin": false
  },
  "api": {
    "require_api_key": false,
    "require_admin_api_key": false,
    "admin_api_key": "supersecretadminkey456"
  },
  "reports": {
    "redact_by_default": true,
    "redacted_keys": [
      "api_key",
      "x_api_key",
      "authorization",
      "token",
      "secret",
      "password"
    ],
    "max_export_bytes": 262144,
    "cleanup_max_age_days": 7,
    "cleanup_glob": "*.json"
  },
  "logging": {
    "cleanup_max_age_days": 30
  }
}
