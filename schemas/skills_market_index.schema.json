{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://titantshift.local/schemas/skills_market_index.schema.json",
  "title": "Skills Market Remote Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source",
    "generated_at",
    "signing_version",
    "items"
  ],
  "properties": {
    "source": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "signing_version": {
      "type": "string",
      "enum": ["v1", "v2-ed25519"]
    },
    "index_hash": {
      "type": "string"
    },
    "public_key": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "description",
          "mode",
          "domain",
          "version",
          "tags",
          "required_tools",
          "dependencies"
        ],
        "properties": {
          "skill_id": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "mode": {"type": "string"},
          "domain": {"type": "string"},
          "version": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "required_tools": {"type": "array", "items": {"type": "string"}},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "prompt_template": {"type": ["string", "null"]}
        }
      }
    }
  }
}
