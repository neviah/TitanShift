{
  "runtime": {
    "module_path": "modules",
    "enable_hot_reload": false
  },
  "orchestrator": {
    "enable_subagents": false,
    "default_role": "General Agent",
    "skill_execution_timeout_s": 15.0
  },
  "skills": {
    "market_registry_file": "skills_market_registry.json",
    "market_installed_file": "skills_market_installed.json"
  },
  "model": {
    "default_backend": "local_stub",
    "allow_cloud_adapters": true,
    "lmstudio": {
      "base_url": "http://127.0.0.1:1234/v1",
      "model": "local-model",
      "timeout_s": 45.0
    }
  },
  "memory": {
    "storage_dir": ".harness",
    "sqlite_file": "memory.db",
    "graph_file": "graph.json",
    "semantic_backend": "sqlite",
    "enable_chroma": false,
    "graph_backend": "networkx"
  },
  "tools": {
    "deny_all_by_default": true,
    "allow_network": false,
    "allowed_paths": ["."],
    "allowed_tool_names": ["shell_command"],
    "blocked_tool_names": [],
    "allowed_command_prefixes": ["where", "git", "python", "dir", "echo"]
  },
  "execution": {
    "allowed_cwd_roots": ["."],
    "allowed_command_prefixes": ["where", "git", "python", "dir", "echo"],
    "max_runtime_s": 30,
    "max_output_bytes": 32768
  },
  "state_machine": {
    "default_budget": {
      "max_steps": 1,
      "max_tokens": 8192,
      "max_duration_ms": 60000
    }
  },
  "ingestion": {
    "enable_graphify_plugin": false,
    "dedupe_threshold": 1.0,
    "confidence_min": 0.0
  },
  "logging": {
    "file": "events.log",
    "cleanup_max_age_days": 30
  },
  "scheduler": {
    "heartbeat_timeout_s": 120,
    "enable_maintenance_jobs": false,
    "maintenance_health_interval_s": 300,
    "maintenance_retention_interval_s": 1800
  },
  "api": {
    "require_api_key": false,
    "api_key": "",
    "require_admin_api_key": false,
    "admin_api_key": ""
  },
  "reports": {
    "redact_by_default": true,
    "redacted_keys": ["api_key", "x_api_key", "authorization", "token", "secret", "password"],
    "max_export_bytes": 262144,
    "cleanup_max_age_days": 7,
    "cleanup_glob": "*.json"
  }
}
