{
  "runtime": {
    "module_path": "modules",
    "enable_hot_reload": false
  },
  "orchestrator": {
    "enable_subagents": false,
    "default_role": "General Agent",
    "skill_execution_timeout_s": 15.0,
    "lightning_mode": {
      "auto_route_through_skills": true,
      "max_tool_calls_per_response": 5,
      "default_budget": {
        "max_steps": 60,
        "max_tokens": 12000,
        "max_duration_ms": 90000
      }
    }
  },
  "skills": {
    "market_registry_file": "skills_market_registry.json",
    "market_installed_file": "skills_market_installed.json",
    "market_remote_cache_file": "skills_market_remote_cache.json",
    "market_remote_status_file": "skills_market_remote_status.json",
    "market_remote_timeout_s": 10.0,
    "market_remote_min_sync_seconds": 0,
    "market_trusted_public_keys": [],
    "market_allow_v1_hash_fallback": true
  },
  "model": {
    "default_backend": "local_stub",
    "allow_cloud_adapters": true,
    "lmstudio": {
      "base_url": "http://127.0.0.1:1234/v1",
      "model": "local-model",
      "timeout_s": 45.0
    },
    "openai_compatible": {
      "base_url": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-4o-mini",
      "api_key": "",
      "timeout_s": 45.0,
      "max_tokens": 2048,
      "temperature": 0.2,
      "referrer": "",
      "app_title": "TitanShift"
    }
  },
  "memory": {
    "storage_dir": ".harness",
    "sqlite_file": "memory.db",
    "graph_file": "graph.json",
    "semantic_backend": "sqlite",
    "enable_chroma": false,
    "graph_backend": "networkx",
    "neo4j": {
      "uri": "",
      "username": "",
      "password": "",
      "database": ""
    }
  },
  "tools": {
    "deny_all_by_default": true,
    "allow_network": false,
    "allowed_paths": [
      "."
    ],
    "allowed_tool_names": [
      "shell_command",
      "web_fetch",
      "create_directory",
      "init_project",
      "generate_component",
      "generate_route",
      "write_file",
      "append_file",
      "replace_in_file",
      "json_edit",
      "insert_at_line",
      "delete_range",
      "yaml_edit",
      "read_file",
      "list_directory",
      "rename_or_move",
      "delete_file",
      "search_workspace",
      "run_project_check",
      "run_tests",
      "lint_and_fix",
      "version_bump",
      "generate_release_notes",
      "tag_and_publish_release",
      "patch_file",
      "install_dependencies",
      "index_project",
      "read_context",
      "propose_wiring",
      "apply_wiring",
      "officecli_create_document",
      "officecli_add_element",
      "officecli_view_document",
      "officecli_set_properties",
      "officecli_merge_template",
      "officecli_batch"
    ],
    "blocked_tool_names": [],
    "allowed_command_prefixes": [
      "where",
      "git",
      "python",
      "npm",
      "curl",
      "dir",
      "echo",
      "officecli"
    ]
  },
  "tools": {
    "deny_all_by_default": true,
    "allow_network": false,
    "allowed_paths": ["."],
    "allowed_tool_names": [
      "shell_command",
      "web_fetch",
      "create_directory",
      "write_file",
      "append_file",
      "replace_in_file",
      "json_edit",
      "read_file",
      "list_directory",
      "rename_or_move",
      "delete_file",
      "search_workspace",
      "run_project_check",
      "run_tests",
      "lint_and_fix",
      "insert_at_line",
      "delete_range",
      "yaml_edit",
      "patch_file",
      "install_dependencies",
      "index_project",
      "read_context",
      "propose_wiring",
      "apply_wiring",
      "init_project",
      "generate_component",
      "generate_route",
      "version_bump",
      "generate_release_notes",
      "tag_and_publish_release",
      "generate_report",
      "generate_chart",
      "generate_svg_asset",
      "officecli_create_document",
      "officecli_add_element",
      "officecli_view_document",
      "officecli_set_properties",
      "officecli_merge_template",
      "officecli_batch"
    ],
    "blocked_tool_names": [],
    "allowed_command_prefixes": ["where", "git", "python", "npm", "curl", "dir", "echo", "officecli"]
  },
  "execution": {
    "allowed_cwd_roots": ["."],
    "allowed_command_prefixes": ["where", "git", "python", "npm", "curl", "dir", "echo"],
    "max_runtime_s": 30,
    "max_output_bytes": 32768,
    "sandbox_env": false,
    "allowed_env_vars": ["PATH", "HOME", "USER", "USERPROFILE", "SYSTEMROOT", "TEMP", "TMP"]
  },
  "state_machine": {
    "default_budget": {
      "max_steps": 1,
      "max_tokens": 8192,
      "max_duration_ms": 60000
    }
  },
  "ingestion": {
    "enable_graphify_plugin": false,
    "dedupe_threshold": 1.0,
    "confidence_min": 0.0
  },
  "logging": {
    "file": "events.log",
    "cleanup_max_age_days": 30
  },
  "scheduler": {
    "heartbeat_timeout_s": 120,
    "enable_maintenance_jobs": false,
    "maintenance_health_interval_s": 300,
    "maintenance_retention_interval_s": 1800
  },
  "api": {
    "require_api_key": false,
    "api_key": "",
    "require_admin_api_key": false,
    "admin_api_key": ""
  },
  "reports": {
    "redact_by_default": true,
    "redacted_keys": ["api_key", "x_api_key", "authorization", "token", "secret", "password"],
    "max_export_bytes": 262144,
    "cleanup_max_age_days": 7,
    "cleanup_glob": "*.json"
  }
}
