{
  "title": "TitanShift Observability",
  "uid": "titanshift-main",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Runs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "titanshift_runs_active",
          "legendFormat": "active"
        }
      ],
      "options": { "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(titanshift_requests_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(titanshift_requests_total{status_class=~\"4xx|5xx\"}) / sum(titanshift_requests_total)",
          "legendFormat": "error rate"
        }
      ],
      "options": {
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.1 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate by Status Class",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(titanshift_requests_total[1m]))",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p95 Latency by Path (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "titanshift_request_duration_ms_p95",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Tool Calls by Tool & Outcome",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (tool, outcome) (titanshift_tool_calls_total)",
          "legendFormat": "{{tool}} / {{outcome}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Avg Tool Duration (seconds)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "titanshift_tool_duration_seconds_avg",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Tasks by Status",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "titanshift_tasks_total",
          "legendFormat": "{{status}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
